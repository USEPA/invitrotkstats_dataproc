+       save(smeltz2023.red,smeltz2023.uc,smeltz2023.clint,
+            smeltz2023.red.L3,smeltz2023.uc.L3,smeltz2023.clint.L3,
+            smeltz2023.red.L4,smeltz2023.uc.L4,smeltz2023.clint.L4,
