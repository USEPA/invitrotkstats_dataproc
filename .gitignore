## Parent Files to Ignore ##
# History files
.Rhistory
.Rapp.history

# Session Data files
.RData

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# HTML's generated by R markdown or markdown files
README.html
working/NOTES_working.html

# R Environment Variables
.Renviron

# Package binaries
*.tar.gz

# Personal Filepath to Git Repo Clone
final_RData/gitpath.RData
final_RData/gitpath*.RData
# R out files from programmatically running data for package script - ignore for now
final_RData/*[0-9].Rout
final_RData/Rout_archive

# Ignore Temporary/Draft/Intermediate Files #
working/Wambaugh2019/TMP*
working/Wambaugh2019/rscripts/TMP*
working/Wambaugh2019/rscripts/*.pdf
working/Wambaugh2019/*.pdf

## Ignore Temporary/Intermediate Wambaugh2019 Files ##
# ignore the intermediate RData chem_split data files - keep ignore Bayes tsv files
working/Wambaugh2019/data/L4_chem_split/*.RData
# ignore the interim files for L4 estimation
working/Wambaugh2019/data/L4_interim/
# ignore the archive data files
working/Wambaugh2019/data/ARCHIVE_data
# ignore the Rout files from previous runs (dated runs)
working/Wambaugh2019/rscripts/Rout/Rout_[0-9]*
