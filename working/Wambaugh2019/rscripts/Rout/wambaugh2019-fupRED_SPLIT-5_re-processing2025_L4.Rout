> dim(wambaugh2019.red.L2.SPLIT[[chem.group]])
[1] 1551   28
> # show the number of chemicals to be evaluated with this chemical split
> length(unique(wambaugh2019.red.L2.SPLIT[[chem.group]]$Compound.Name))
[1] 50
> ## Process L2 to L4 ##
> tictoc::tic()
> jags_path <- runjags::findJAGS()
INFO: Could not find files for the given pattern(s).
> tmp.wambaugh2019.red.L4 <- invitroTKstats::calc_fup_red(
