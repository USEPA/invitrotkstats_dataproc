> length(unique(wambaugh2019.clint.L2.SPLIT[[chem.group]]$Compound.Name))
[1] 79
> ## Process L2 to L4 ##
> tictoc::tic()
> jags_path <- runjags::findJAGS()
INFO: Could not find files for the given pattern(s).
> tmp.wambaugh2019.clint.L4 <- invitroTKstats::calc_clint(
